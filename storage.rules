rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth.token.admin == true;
    }
    match /images/{any} {
      allow read: if true;
    }
    match /utmblog/{any} {
      allow read: if true;
    }
    match /sounds/{any} {
      allow read: if true;
    }
    match /music/{any} {
      allow read: if true;
    }
  }
}
