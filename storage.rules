rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth.token.admin == true;
    }
    match /avatars/{any} {
      allow read, write: if true;
    }
    match /chatFiles/{folders=**} {
      allow read, write: if request.auth.uid != null;
    }
  }
}
